             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{"ExponentFunction", "->", 
              RowBox[{"(", 
               RowBox[{"Null", " ", "&"}], ")"}]}]}], "]"}], "]"}]}], "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"WriteString", "[", 
         RowBox[{"file", ",", " ", "\"\<, \>\""}], "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"file", ",", " ", "\"\<};\\n\\n\>\""}], "]"}], ";", 
